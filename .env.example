# TwitsTreatsDB Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git - it contains sensitive credentials

# ============================================================
# ORACLE DATABASE CONNECTION
# ============================================================

# Oracle database host/IP address
ORACLE_HOST=localhost

# Oracle database port (default: 1521)
ORACLE_PORT=1521

# Oracle SID or Service Name
# Use ORCL for local standalone, or your service name
ORACLE_SID=ORCL

# Oracle username
ORACLE_USER=system

# Oracle password
ORACLE_PASSWORD=your_password_here

# ============================================================
# CONNECTION POOL SETTINGS
# ============================================================

# Minimum connections in pool
CONNECTION_POOL_MIN=2

# Maximum connections in pool
CONNECTION_POOL_MAX=10

# ============================================================
# APPLICATION SETTINGS
# ============================================================

# Enable debug mode (true/false)
DEBUG=false

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================
# ETL SETTINGS
# ============================================================

# ETL export formats (csv, json, parquet, all)
ETL_EXPORT_FORMATS=all

# ETL export directory
ETL_EXPORT_DIR=data_exports

# ============================================================
# EXAMPLE CONFIGURATIONS
# ============================================================

# For local Oracle Express Edition:
# ORACLE_HOST=localhost
# ORACLE_PORT=1521
# ORACLE_SID=XE
# ORACLE_USER=system
# ORACLE_PASSWORD=password

# For remote Oracle database:
# ORACLE_HOST=192.168.1.100
# ORACLE_PORT=1521
# ORACLE_SID=PROD_DB
# ORACLE_USER=app_user
# ORACLE_PASSWORD=secure_password_here
